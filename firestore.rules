rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lost & Found: logged-in user creates with own userId; can read/update only own docs
    match /lost_found_items/{docId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Complaints: same as above
    match /complaints/{docId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Volunteers: any logged-in user can read all; create only with own userId; update/delete only own
    match /volunteers/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
